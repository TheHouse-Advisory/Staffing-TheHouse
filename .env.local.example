# ─────────────────────────────────────────────────────────────
#  Staffing Hub — Variables de Entorno
#  Copia este archivo a .env.local y completa los valores
# ─────────────────────────────────────────────────────────────

# Supabase — Project URL y Anon Key (públicas, van al cliente)
# Las encuentras en: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Supabase — Service Role Key (PRIVADA, solo para server actions / scripts)
# NUNCA la expongas al cliente
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui
